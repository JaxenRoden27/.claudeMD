rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function hasOnlyKeys(keys) {
      return request.resource.data.keys().hasOnly(keys);
    }

    function conversationPath(conversationId) {
      return /databases/$(database)/documents/conversations/$(conversationId);
    }

    function conversationExists(conversationId) {
      return exists(conversationPath(conversationId));
    }

    function conversationData(conversationId) {
      return get(conversationPath(conversationId)).data;
    }

    function isConversationMember(conversationId) {
      return signedIn()
        && conversationExists(conversationId)
        && uid() in conversationData(conversationId).participantUserIds;
    }

    function isDeviceOwner(userId, deviceId) {
      return isSelf(userId)
        && exists(/databases/$(database)/documents/public_user_bundles/$(userId)/devices/$(deviceId));
    }

    function validPrivateUserDoc(userId) {
      return hasOnlyKeys([
        'userId',
        'createdAt',
        'updatedAt',
        'accountState',
        'discoverability',
        'profileCiphertext',
        'profileVersion',
      ]) && request.resource.data.userId == userId;
    }

    function validPublicBundleDoc(userId) {
      return hasOnlyKeys([
        'userId',
        'createdAt',
        'updatedAt',
        'deviceListVersion',
        'identityAuditVersion',
      ]) && request.resource.data.userId == userId;
    }

    function validDeviceRoutingDoc(userId, deviceId) {
      return hasOnlyKeys([
        'userId',
        'deviceId',
        'fcmToken',
        'platform',
        'updatedAt',
      ]) &&
      request.resource.data.userId == userId &&
      request.resource.data.deviceId == deviceId &&
      request.resource.data.fcmToken is string &&
      request.resource.data.platform is string;
    }

    function validDemoAliasDoc(alias) {
      return hasOnlyKeys([
        'alias',
        'userId',
        'label',
        'updatedAt',
      ]) &&
      request.resource.data.alias == alias &&
      request.resource.data.userId == uid() &&
      request.resource.data.label is string;
    }

    function validDeviceDoc(userId, deviceId) {
      return hasOnlyKeys([
        'userId',
        'deviceId',
        'registrationId',
        'identityKeyPublic',
        'signedPreKey',
        'preKeyCount',
        'capabilities',
        'status',
        'deviceOrdinal',
        'deviceNameCiphertext',
        'createdAt',
        'lastSeenAt',
        'updatedAt',
      ]) &&
      request.resource.data.userId == userId &&
      request.resource.data.deviceId == deviceId &&
      request.resource.data.registrationId is int &&
      request.resource.data.identityKeyPublic is string &&
      request.resource.data.preKeyCount is int &&
      request.resource.data.status in ['active', 'revoked', 'inactive'];
    }

    function validOneTimePreKeyDoc(userId, deviceId, preKeyId) {
      return hasOnlyKeys([
        'userId',
        'deviceId',
        'preKeyId',
        'publicKey',
        'state',
        'uploadedAt',
        'claimedAt',
        'claimedByUserIdHash',
      ]) &&
      request.resource.data.userId == userId &&
      request.resource.data.deviceId == deviceId &&
      request.resource.data.preKeyId == preKeyId &&
      request.resource.data.publicKey is string &&
      request.resource.data.state in ['available', 'claimed'];
    }

    function validConversationCreate(conversationId) {
      return hasOnlyKeys([
        'conversationId',
        'type',
        'participantUserIds',
        'participantSetHash',
        'createdBy',
        'createdAt',
        'latestMessageAt',
        'policy',
        'groupId',
      ]) &&
      request.resource.data.conversationId == conversationId &&
      request.resource.data.createdBy == uid() &&
      request.resource.data.participantUserIds is list &&
      uid() in request.resource.data.participantUserIds &&
      request.resource.data.participantUserIds.size() >= 2 &&
      request.resource.data.type in ['direct', 'group'];
    }

    function validDeviceMessageCreate(conversationId) {
      return hasOnlyKeys([
        'conversationId',
        'messageId',
        'senderUserId',
        'senderDeviceId',
        'recipientUserId',
        'recipientDeviceId',
        'messageType',
        'protocolVersion',
        'envelopeCiphertext',
        'attachmentRefs',
        'createdAt',
        'expiresAt',
        'serverOrder',
        'deliveryState',
      ]) &&
      request.resource.data.conversationId == conversationId &&
      request.resource.data.senderUserId == uid() &&
      request.resource.data.messageId is string &&
      request.resource.data.senderDeviceId is string &&
      request.resource.data.recipientUserId is string &&
      request.resource.data.recipientDeviceId is string &&
      request.resource.data.messageType is string &&
      request.resource.data.protocolVersion is int &&
      request.resource.data.envelopeCiphertext is string &&
      request.resource.data.deliveryState in ['queued', 'delivered', 'read', 'expired'] &&
      request.resource.data.recipientUserId in conversationData(conversationId).participantUserIds;
    }

    function deviceMessageReadAllowed() {
      return signedIn() && (
        resource.data.senderUserId == uid() ||
        resource.data.recipientUserId == uid()
      );
    }

    function validConversationUpdate(conversationId) {
      return signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'latestMessageAt',
        ]);
    }

    function deviceMessageDeliveryUpdateAllowed() {
      return signedIn() &&
        resource.data.recipientUserId == uid() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'deliveryState',
        ]) &&
        request.resource.data.deliveryState in ['queued', 'delivered', 'read', 'expired'];
    }

    function validAttachmentDoc(conversationId) {
      return hasOnlyKeys([
        'conversationId',
        'messageId',
        'storagePath',
        'ciphertextHash',
        'sizePadded',
        'headerCiphertext',
        'createdAt',
        'expiresAt',
      ]) &&
      request.resource.data.conversationId == conversationId &&
      request.resource.data.messageId is string &&
      request.resource.data.storagePath is string &&
      request.resource.data.ciphertextHash is string &&
      request.resource.data.sizePadded is int &&
      request.resource.data.headerCiphertext is string;
    }

    function validKeyAuditEvent() {
      return hasOnlyKeys([
        'ownerUserId',
        'peerUserId',
        'deviceId',
        'eventType',
        'oldIdentityKeyHash',
        'newIdentityKeyHash',
        'occurredAt',
        'actorUserId',
      ]) &&
      request.resource.data.actorUserId == uid();
    }

    function validGroupDoc(groupId) {
      return hasOnlyKeys([
        'groupId',
        'createdBy',
        'createdAt',
        'currentEpoch',
        'membershipVersion',
        'groupStateCiphertext',
      ]) &&
      request.resource.data.groupId == groupId &&
      request.resource.data.createdBy == uid() &&
      request.resource.data.currentEpoch is int &&
      request.resource.data.membershipVersion is int &&
      request.resource.data.groupStateCiphertext is string;
    }

    function validGroupMemberDoc(groupId, memberId) {
      return hasOnlyKeys([
        'groupId',
        'memberId',
        'userId',
        'deviceId',
        'role',
        'state',
        'joinedEpoch',
        'removedEpoch',
        'createdAt',
      ]) &&
      request.resource.data.groupId == groupId &&
      request.resource.data.memberId == memberId &&
      request.resource.data.userId is string &&
      request.resource.data.deviceId is string &&
      request.resource.data.role in ['admin', 'member'] &&
      request.resource.data.state in ['active', 'removed'] &&
      request.resource.data.joinedEpoch is int;
    }

    match /users_private/{userId} {
      allow read: if isSelf(userId);
      allow create, update: if isSelf(userId) && validPrivateUserDoc(userId);
      allow delete: if isSelf(userId);

      match /device_routing/{deviceId} {
        allow read: if isSelf(userId);
        allow create, update: if isSelf(userId) && validDeviceRoutingDoc(userId, deviceId);
        allow delete: if isSelf(userId);
      }
    }

    match /demo_aliases/{alias} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validDemoAliasDoc(alias);
      allow delete: if false;
    }

    match /public_user_bundles/{userId} {
      allow read: if signedIn();
      allow create, update: if isSelf(userId) && validPublicBundleDoc(userId);
      allow delete: if false;

      match /devices/{deviceId} {
        allow read: if signedIn();
        allow create, update: if isSelf(userId) && validDeviceDoc(userId, deviceId);
        allow delete: if isSelf(userId);

        match /one_time_prekeys/{preKeyId} {
          allow read: if signedIn();
          allow create, update: if isSelf(userId) && validOneTimePreKeyDoc(userId, deviceId, preKeyId);
          allow delete: if isSelf(userId);
        }
      }
    }

    match /conversations/{conversationId} {
      allow read: if isConversationMember(conversationId);
      allow create: if validConversationCreate(conversationId);
      allow update: if isConversationMember(conversationId) && validConversationUpdate(conversationId);
      allow delete: if false;

      match /device_messages/{deliveryId} {
        allow read: if isConversationMember(conversationId) && deviceMessageReadAllowed();
        allow create: if isConversationMember(conversationId) && validDeviceMessageCreate(conversationId);
        allow update: if isConversationMember(conversationId) && deviceMessageDeliveryUpdateAllowed();
        allow delete: if false;
      }

      match /attachments/{attachmentId} {
        allow read: if isConversationMember(conversationId);
        allow create: if isConversationMember(conversationId) && validAttachmentDoc(conversationId);
        allow update, delete: if false;
      }
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && validGroupDoc(groupId);
      allow update, delete: if false;

      match /members/{memberId} {
        allow read: if signedIn();
        allow create, update, delete: if false;
      }
    }

    match /key_audit_events/{eventId} {
      allow read: if signedIn() && (
        resource.data.ownerUserId == uid() ||
        resource.data.peerUserId == uid()
      );
      allow create: if signedIn() && validKeyAuditEvent();
      allow update, delete: if false;
    }

    match /forums_posts/{postId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /app_groups/{groupId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }
  }
}
